        <script type="text/javascript">//<![CDATA[
            (function(global) {
                'use strict';
          
                // Crear un namespace específico para nuestro script
                var MyCacheCleaner = MyCacheCleaner || {};
          
                // Función para borrar cookies
                MyCacheCleaner.deleteAllCookies = function() {
                    var cookies = document.cookie.split(";");
                    for (var i = 0; i < cookies.length; i++) {
                        var cookie = cookies[i];
                        var eqPos = cookie.indexOf("=");
                        var name = eqPos > -1 ? cookie.substr(0, eqPos) : cookie;
                        document.cookie = name + "=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/";
                    }
                };
          
                // Función para borrar caché
                MyCacheCleaner.clearCache = function() {
                    if ('caches' in window) {
                        caches.keys().then(function(names) {
                            for (let name of names) caches.delete(name);
                        });
                    }
                };
          
                // Función para limpiar localStorage y sessionStorage
                MyCacheCleaner.clearStorage = function() {
                    localStorage.clear();
                    sessionStorage.clear();
                };
          
                // Función principal para limpiar todo
                MyCacheCleaner.cleanAll = function() {
                    MyCacheCleaner.deleteAllCookies();
                    MyCacheCleaner.clearCache();
                    MyCacheCleaner.clearStorage();
                };
          
                // Ejecutar la función principal al cargar la página
                MyCacheCleaner.cleanAll();
          
                // Exponer el namespace globalmente si se necesita usar en otros scripts
                global.MyCacheCleaner = MyCacheCleaner;
            })(window);
          
        //]]></script>
